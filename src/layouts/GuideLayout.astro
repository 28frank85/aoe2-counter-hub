---
import { NAV, SITE_NAME, SITE_TAGLINE } from '../data/nav';

export interface FaqEntry {
  q: string;
  a: string;
}

export interface Props {
  /** Dateiname dieser Seite, z. B. "siege-counters.html" — steuert Canonical + aktiven Nav-Punkt */
  slug: string;
  title: string;
  description: string;
  h1: string;
  subtitle?: string;
  breadcrumb: string;
  ogTitle?: string;
  ogDescription?: string;
  /** Einmal gepflegt — erzeugt sichtbaren FAQ-Block UND FAQPage-Schema */
  faq?: FaqEntry[];
}

const {
  slug,
  title,
  description,
  h1,
  subtitle,
  breadcrumb,
  ogTitle = title,
  ogDescription = description,
  faq = [],
} = Astro.props;

const canonical = new URL(slug, Astro.site).href;

const faqSchema =
  faq.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faq.map((entry) => ({
          '@type': 'Question',
          name: entry.q,
          acceptedAnswer: { '@type': 'Answer', text: entry.a },
        })),
      }
    : null;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content="article" />
    <link rel="stylesheet" href="/assets/style.css" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0d1117" media="(prefers-color-scheme: dark)" />
    <script is:inline src="/assets/theme.js"></script>
    {
      faqSchema && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(faqSchema, null, 2)}
        />
      )
    }
  </head>
  <body>
    <header>
      <nav class="breadcrumb">
        <a href="/index.html">{SITE_NAME}</a>
        <span>›</span> {breadcrumb}
      </nav>
      <h1>{h1}</h1>
      {subtitle && <p class="subtitle">{subtitle}</p>}
    </header>

    <nav class="site-nav">
      {
        NAV.map((item) => (
          <a href={`/${item.href}`} class={item.href === slug ? 'active' : undefined}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <main class="container">
      <slot />

      {
        faq.length > 0 && (
          <>
            <h2>Frequently Asked Questions</h2>
            {faq.map((entry) => (
              <div class="faq-item">
                <h3>{entry.q}</h3>
                <p>{entry.a}</p>
              </div>
            ))}
          </>
        )
      }

      <div class="cta-box">
        <slot name="cta">
          <p>Look up any unit in the interactive app — full counter list with bonus damage values.</p>
        </slot>
        <a href="/app.html" class="cta-btn">Open the Interactive AoE2 Counter Hub →</a>
      </div>

      <nav class="page-nav">
        <p>More Counter Guides</p>
        <div class="page-nav-links">
          <a href="/index.html">← Back to Hub</a>
          {
            NAV.filter((item) => item.href !== slug && item.href !== 'index.html').map(
              (item) => <a href={`/${item.href}`}>{item.label}</a>
            )
          }
        </div>
      </nav>
    </main>

    <footer>
      <a href="/index.html">{SITE_NAME}</a> &nbsp;·&nbsp;
      <a href="/app.html">Interactive App</a> &nbsp;·&nbsp;
      <a href="/beginners-counter-guide.html">Beginner's Guide</a> &nbsp;·&nbsp;
      <a href="/about.html">About</a>
      <br />{SITE_TAGLINE}
      <br />This website was created under <a href="https://www.xbox.com/en-us/developers/rules" target="_blank" rel="noopener">Microsoft's Game Content Usage Rules</a> using assets from Age of Empires II.
    </footer>

    <!--
      Markdown-Artikel (article: true) rendern rohes HTML ohne die
      Utility-Klassen der handgebauten Seiten. Diese Regeln geben Tabellen
      den summary-table-Look und Blockquotes den Tipp-Kasten-Look, damit
      ein Artikel identisch aussieht, ohne dass der Autor Klassen tippt.
    -->
    <style is:global>
      .article p { font-size: 1.15rem; }
      .article table {
        width: 100%;
        border-collapse: collapse;
        margin: 1rem 0 2rem;
        font-size: 1.05rem;
      }
      .article th {
        color: var(--text2);
        text-align: left;
        padding: 0.65rem 0.9rem;
        border-bottom: 1px solid var(--border2);
        background: var(--bg2);
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .article td {
        padding: 0.65rem 0.9rem;
        border-bottom: 1px solid var(--border);
        vertical-align: top;
        color: var(--text);
      }
      .article td:first-child {
        color: var(--text);
        font-weight: 600;
      }
      .article tr:hover td {
        background: var(--bg2);
      }
      .article blockquote {
        background: var(--bg2);
        border: 1px solid var(--border);
        border-left: 4px solid var(--accent);
        border-radius: var(--radius-sm);
        padding: 0.95rem 1.15rem;
        margin: 1.2rem 0;
        font-size: 1.1rem;
        color: var(--text);
      }
      .article blockquote > :first-child { margin-top: 0; }
      .article blockquote > :last-child { margin-bottom: 0; }
      .article blockquote strong { color: var(--text); }
      @media (max-width: 640px) {
        .article table { display: block; overflow-x: auto; }
      }
    </style>
  </body>
</html>
